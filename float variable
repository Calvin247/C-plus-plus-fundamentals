#include <iostream>   // Allows input and output (cout)

int main()            // The program starts running here
{
    float a = 5.5f;   // Create a float variable called 'a' and store 5.5 in it
                      // The 'f' tells C++ this number is a float so it does not convert double to float first

    float b = 2.0f;   // Another float variable storing 2.0

    float sum = a + b; 

    float product = a * b; 

    std::cout << "Value of a: " << a << std::endl; 

    std::cout << "Value of b: " << b << std::endl;

    std::cout << "Sum: " << sum << std::endl;

    std::cout << "Product: " << product << std::endl;

    return 0;   // Ends the program and tells the OS it finished successfully
}
