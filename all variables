#include <iostream>
#include <string>

using namespace std;

int main()
{
    int age = 24;            // Integer number
    float height = 1.80f;    // Decimal number
    bool isStudent = true;   // True or false value
    string name = "Calvin";  // Text (multiple characters)
    char grade = 'A';        // Single character

    cout << "Name: " << name << endl;
    cout << "Age: " << age << endl;
    cout << "Height: " << height << endl;
    cout << "Student: " << isStudent << endl;
    cout << "Grade: " << grade << endl;

    return 0;
}
